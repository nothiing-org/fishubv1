RewriteEngine On

# -----------------------------------
# 1. Allow real files & folders
# -----------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -----------------------------------
# 2. Route everything else → router.php
# -----------------------------------
RewriteRule ^([A-Za-z0-9\-_]+)$ router.php [L,QSA]
